import pandas as pd 
import numpy as np 
df = pd.read_csv("cirrhosis.csv")
patient_ID = df.loc[15, 'ID'] #use st.selectbox(...) when importing Streamlit to allow user to pick patient ID 
bilirubin = 0 
albumin = 0 
ascites = 0 
endcepathology_level = 0 
inr = 0 
#defining calculation function 
def calculate_child_pugh (bilirubin, albumin, ascites, endcepathology_level, inr):
    result = bilirubin + albumin + ascites + endcepathology_level + inr  
    if 5 <= result <= 6:
        message = "Class A.The patient has mild liver cirrhosis. Survival rate is 85-100%."
    elif 7 <= result <= 9:
        message = "Class B.The patient has moderate liver cirrhosis. More symptoms might emerge. Survival rate is 60-80%"
    elif 10 <= result <= 15:
        message = "Class C. The patient has severe liver cirrhosis. Look into transplants immediately. Survival rate is 35-45%"
    return result and message 

