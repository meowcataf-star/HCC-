import streamlit as sd
import pandas as pd 
import numpy as np 
import matplotlib as plt
import seaborn as sns
df = pd.read_csv("cirrhosis.csv")
#welcome message 
sd.title("Child Pugh Score Calculator.")
sd.header ("This calculator is for educational purposes only.")
sd.sidebar.header("Patient Child Pugh Scores")
patient_ID = df.loc['ID'].unique()
selected_ID = sd. selectbox ("Select Patient ID", options=patient_ID) 
patient_data = df[df['ID']==selected_ID].iloc[0]
bilirubin = 0 
albumin = 0 
ascites = 0 
endcepathology_level = 0 
inr = 0 
#defining calculation function 
def calculate_child_pugh (bilirubin, albumin, ascites, endcepathology_level, inr):
    result = bilirubin + albumin + ascites + endcepathology_level + inr  
    if 5 <= result <= 6: 
        message = str("This patiebnt has mild liver cirrhosis")
        class_level = str("Class A")
        risk = "Survival rate is 85-100%"
    elif 7 <= result <= 9:
        message = str("The patient has moderate liver cirrhosis. More symptoms might emerge.")
        class_level = str("Class B")
        risk = str("Survival rate is 60-80%")
    elif 10 <= result <= 15:
        message = "The patient has severe liver cirrhosis. Look into transplants immediately."
        class_level = str("Class C")
        risk = str("Survival rate is 35-45%")
    return {
        "score": result,
        "class": class_level,
        "advice": message,
        "rate": risk 
    }
df['Child_Pugh_Score'] = df.apply(calculate_child_pugh, axis=1)
sd.sidebar.header ("Patient Data")
#defining bilirubin parameters 
pv_bilirubin = sd.sidebar.slider(
    "Choose Bilirubin level", 
    0.0, 28.0, 1.0,
    float(patient_data['Bilirubin']) 
     )
if pv_bilirubin < 2:
    bilirubin = 1
elif 2 <= pv_bilirubin <= 3:
    bilirubin = 2 
elif pv_bilirubin > 3:
    bilirubin = 3 
#defining albumin parameters
pv_al = sd.sidebar.slider(
    "Choose Albumin level", 
    0.0, 4.64, 1.0,
    float(patient_data ['Albumin'])
     )
if pv_al > 3.5:
    albumin = 1
elif 2.8 <= pv_al <= 3.5:
    albumin = 2
elif pv_al < 2.8: 
    albumin = 3
#defining ascites parameters 
pv_as = sd.sidebar.selectbox (
    "Ascites Presence", 
    ["N", "NA", "Y"],
    str(patient_data['Ascites'])
    )
if pv_as == "Y":
    ascites = 3
elif pv_as == "NA":
    ascites = 2
elif pv_as == "N":
    ascites = 1
#defining INR parameters 
PT = sd.sidebar.slider (
    "Choose Prothrombin level", 
    10.0, 28.0, 1.0,
    float(patient_data['Prothrombin'])
    )
if PT/12 <1.7:
    inr = 1
elif 1.7 <= PT/12 <= 2.3: 
    inr = 2 
elif PT/12 >2.3: 
    inr = 3 
#defining endce. parameters 
pv_stage = sd.sidebar.selectbox(
    "Choose Stage", 
    ["1", "2", "3", "4"],
    str(patient_data["Staga"])
    )
if pv_stage in [1,2,3]:
    endcepathology_level = 1 
elif pv_stage == 4 and bilirubin == 2: 
    endcepathology_level = 2 
elif pv_stage == 4 and bilirubin == 3: 
    endcepathology_level = 3 
#print ("Adding " + str(endcepathology_level) + " points to the score!")
conclusion = calculate_child_pugh(bilirubin, albumin, ascites, endcepathology_level, inr)
sd.subheader(f"Child Pugh Score: {conclusion}")
#graphing/plotting 
sd. subheader("Relationship between Stage and Cirrhosis Risk")
fig, ax = plt.subplots() #created the canvas - area for graphing 
sns.barplot( 
    data=df, 
    x= 'Stage', 
    order= [1,2,3,4],
    y= 'Child_Pugh_Score',
    ax=ax
)
sd.pyplot(fig) #show on app 

